# ═══════════════════════════════════════════════════════════════
# Blumen Vision — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ═══════════════════════════════════════════════════════════════

# ── Banco de Dados (Cloud SQL PostgreSQL 17) ──────────────────
# Formato: postgresql://USER:PASSWORD@HOST:5432/DATABASE
DATABASE_URL="postgresql://blumen_user:SUA_SENHA@34.39.178.94:5432/blumenvision?schema=public"

# ── Google Gemini AI ──────────────────────────────────────────
GEMINI_API_KEY="sua-chave-gemini-aqui"

# ── Google Cloud Storage (opcional, para uploads) ─────────────
# GCS_BUCKET_NAME="blumenvision-uploads"
# GOOGLE_APPLICATION_CREDENTIALS="/path/to/service-account.json"

# ── Aplicação ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

