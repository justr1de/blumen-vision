# ============================================================
# Blúmen Vision — Variáveis de Ambiente (GCP)
# Copie este arquivo para .env e preencha os valores
# ============================================================

# ── Banco de Dados (Cloud SQL PostgreSQL) ────────────────────
# Formato: postgresql://USER:PASSWORD@/DATABASE?host=/cloudsql/PROJECT:REGION:INSTANCE
DATABASE_URL=postgresql://blumen_admin:SUA_SENHA@/blumenvision?host=/cloudsql/blumenvision:southamerica-east1:blumen-vision-db

# ── Autenticação ─────────────────────────────────────────────
JWT_SECRET=gere_um_secret_seguro_com_openssl_rand_base64_32

# ── Google Cloud ─────────────────────────────────────────────
GCP_PROJECT_ID=blumenvision
GCS_BUCKET=blumenvision-storage
GEMINI_API_KEY=sua_chave_gemini_api_aqui

# ── Aplicação ────────────────────────────────────────────────
NODE_ENV=production
PORT=8080

# ── Firebase Auth (quando implementado) ──────────────────────
# FIREBASE_PROJECT_ID=blumenvision
# FIREBASE_API_KEY=sua_firebase_api_key
# FIREBASE_AUTH_DOMAIN=blumenvision.firebaseapp.com

# ── Landing Page Vercel (para redirecionamento) ──────────────
# LANDING_PAGE_URL=https://financeiro-armuti-pmpb.vercel.app
