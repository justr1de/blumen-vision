generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════
// AUTENTICAÇÃO E MULTI-TENANCY
// ═══════════════════════════════════════════════════════════════

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  password      String
  role          Role      @default(VIEWER)
  tenantId      String?
  tenant        Tenant?   @relation(fields: [tenantId], references: [id])
  isMaster      Boolean   @default(false)
  active        Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  messages      Message[] @relation("sender")
  permissions   UserPermission[]

  @@map("users")
}

model Tenant {
  id          String   @id @default(cuid())
  nome        String
  cnpj        String?  @unique
  masterEmail String   @unique
  ativo       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  grupos      Grupo[]
  uploads     Upload[]
  messages    Message[]

  @@map("tenants")
}

model UserPermission {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  module     String   // vision_caixa, vision_capital, vision_producao, vision_decisao, tributario
  canView    Boolean  @default(true)
  canEdit    Boolean  @default(false)
  canExport  Boolean  @default(false)

  @@unique([userId, module])
  @@map("user_permissions")
}

enum Role {
  SUPER_ADMIN
  TENANT_MASTER
  ANALYST
  VIEWER
}

// ═══════════════════════════════════════════════════════════════
// HIERARQUIA GERENCIAL — 3 NÍVEIS LIVRES
// Grupo → Segmento → Unidade
// ═══════════════════════════════════════════════════════════════

model Grupo {
  id          String   @id @default(cuid())
  nome        String
  descricao   String?
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ativo       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  segmentos   Segmento[]

  @@unique([tenantId, nome])
  @@map("grupos")
}

model Segmento {
  id          String   @id @default(cuid())
  nome        String
  descricao   String?
  grupoId     String
  grupo       Grupo    @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  ativo       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  unidades    Unidade[]

  @@unique([grupoId, nome])
  @@map("segmentos")
}

model Unidade {
  id          String   @id @default(cuid())
  nome        String
  cnpj        String?
  endereco    String?
  segmentoId  String
  segmento    Segmento @relation(fields: [segmentoId], references: [id], onDelete: Cascade)
  ativo       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lancamentos   Lancamento[]
  planoContas   PlanoContas[]
  dreItems      DREItem[]
  crediarios    Crediario[]
  patrimoniais  Patrimonial[]
  kpis          KPI[]

  @@unique([segmentoId, nome])
  @@map("unidades")
}

// ═══════════════════════════════════════════════════════════════
// PLANO DE CONTAS
// ═══════════════════════════════════════════════════════════════

model PlanoContas {
  id                  String   @id @default(cuid())
  codigo              String
  nome                String
  nivel               Int
  tipo                String
  codigoPai           String?
  categoriaGerencial  String?
  unidadeId           String
  unidade             Unidade  @relation(fields: [unidadeId], references: [id], onDelete: Cascade)

  lancamentos         Lancamento[]

  @@unique([unidadeId, codigo])
  @@map("plano_contas")
}

// ═══════════════════════════════════════════════════════════════
// LANÇAMENTOS (MOVIMENTO ANALÍTICO)
// ═══════════════════════════════════════════════════════════════

model Lancamento {
  id          String   @id @default(cuid())
  data        DateTime
  codigo      String
  descricao   String
  valor       Float
  tipo        String   // receita, despesa, transferencia
  banco       String?
  categoria   String?
  unidadeId   String
  unidade     Unidade     @relation(fields: [unidadeId], references: [id], onDelete: Cascade)
  contaId     String?
  conta       PlanoContas? @relation(fields: [contaId], references: [id])
  createdAt   DateTime @default(now())

  @@index([unidadeId, data])
  @@index([unidadeId, tipo])
  @@map("lancamentos")
}

// ═══════════════════════════════════════════════════════════════
// DRE (Demonstrativo de Resultado do Exercício)
// ═══════════════════════════════════════════════════════════════

model DREItem {
  id          String   @id @default(cuid())
  codigo      String
  nome        String
  nivel       Int
  tipo        String
  codigoPai   String?
  valores     Json
  total       Float
  unidadeId   String
  unidade     Unidade  @relation(fields: [unidadeId], references: [id], onDelete: Cascade)

  @@unique([unidadeId, codigo])
  @@map("dre_items")
}

// ═══════════════════════════════════════════════════════════════
// CREDIÁRIO (Contas a Receber)
// ═══════════════════════════════════════════════════════════════

model Crediario {
  id            String   @id @default(cuid())
  clienteNome   String
  valorOriginal Float
  valorPago     Float
  saldo         Float
  status        String
  dataVenda     DateTime
  unidadeId     String
  unidade       Unidade  @relation(fields: [unidadeId], references: [id], onDelete: Cascade)

  @@index([unidadeId, status])
  @@map("crediarios")
}

// ═══════════════════════════════════════════════════════════════
// PATRIMONIAL (Aportes, Retornos, Empréstimos)
// ═══════════════════════════════════════════════════════════════

model Patrimonial {
  id          String   @id @default(cuid())
  tipo        String
  socio       String
  valor       Float
  data        DateTime
  descricao   String?
  unidadeId   String
  unidade     Unidade  @relation(fields: [unidadeId], references: [id], onDelete: Cascade)

  @@index([unidadeId, tipo])
  @@map("patrimoniais")
}

// ═══════════════════════════════════════════════════════════════
// KPIs POR UNIDADE (snapshot mensal)
// ═══════════════════════════════════════════════════════════════

model KPI {
  id              String   @id @default(cuid())
  periodo         String   // "2026-04"
  receitaTotal    Float    @default(0)
  lucroLiquido    Float    @default(0)
  margemLiquida   Float    @default(0)
  saldoCaixa      Float    @default(0)
  endividamento   Float    @default(0)
  folhaPct        Float    @default(0)
  unidadeId       String
  unidade         Unidade  @relation(fields: [unidadeId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())

  @@unique([unidadeId, periodo])
  @@map("kpis")
}

// ═══════════════════════════════════════════════════════════════
// UPLOADS DE PLANILHAS
// ═══════════════════════════════════════════════════════════════

model Upload {
  id          String   @id @default(cuid())
  filename    String
  storagePath String
  mimeType    String
  size        Int
  status      String   @default("pending")
  resultado   Json?
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("uploads")
}

// ═══════════════════════════════════════════════════════════════
// MENSAGENS (Cliente → Admin)
// ═══════════════════════════════════════════════════════════════

model Message {
  id          String   @id @default(cuid())
  assunto     String
  conteudo    String
  lida        Boolean  @default(false)
  senderId    String
  sender      User     @relation("sender", fields: [senderId], references: [id])
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  createdAt   DateTime @default(now())

  @@index([tenantId, lida])
  @@map("messages")
}
